{
  "framework": "nextjs",
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/mods",
      "destination": "/browse",
      "permanent": false
    }
  ],
  "crons": [
    {
      "path": "/api/cron/refresh-stars",
      "schedule": "0 3 * * *"
    }
  ]
}
